{
  "name": "mx-performance",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <25"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "rm -rf dist",
    "check:bundle-size": "node scripts/check_bundle_size.mjs",
    "lint": "tsc --noEmit && node scripts/lint-tokens-ast.mjs && eslint 'src/**/*.{ts,tsx}'",
    "lint:tokens": "node scripts/lint-tokens-ast.mjs",
    "lint:tokens:legacy": "node scripts/lint-tokens.legacy.js",
    "lint:a11y": "eslint 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/lib src/benchmarks src/hooks src/components src/features src/pages src/test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "sync:ide": "node .aiox-core/infrastructure/scripts/ide-sync/index.js sync",
    "sync:ide:check": "node .aiox-core/infrastructure/scripts/ide-sync/index.js validate",
    "sync:skills:codex": "node .aiox-core/infrastructure/scripts/codex-skills-sync/index.js",
    "sync:skills:codex:global": "node .aiox-core/infrastructure/scripts/codex-skills-sync/index.js --global",
    "validate:structure": "node .aiox-core/infrastructure/scripts/validate-paths.js",
    "validate:agents": "node .aiox-core/infrastructure/scripts/validate-agents.js",
    "deploy": "vercel --prod",
    "fix:admin-access": "tsx scripts/fix_admin_access.ts",
    "seed:sandbox:live": "tsx scripts/seed_live_sandbox.ts",
    "validate:e2e:live": "tsx scripts/validate_live_end_to_end.ts",
    "validate:admin-master:e2e:live": "node scripts/validate_admin_master_full_e2e.mjs",
    "export:team-contacts": "tsx scripts/export_team_contacts.ts",
    "reconcile:pre-cadastro-team": "node scripts/reconcile_pre_cadastro_team.mjs",
    "supabase:update-recovery-email": "node scripts/update_supabase_recovery_email_template.mjs",
    "gen:db-types": "node scripts/gen_db_types.mjs",
    "verify:db-types": "npm run gen:db-types && git diff --exit-code src/types/database.generated.ts",
    "consultoria:carregar-parametros": "tsx scripts/consultoria_carregar_parametros.ts",
    "consultoria:importar-fechamento-mensal": "tsx scripts/consultoria_importar_fechamento_mensal.ts",
    "consultoria:sincronizar-metricas-pmr": "tsx scripts/consultoria_sincronizar_metricas_pmr.ts",
    "consultoria:gerar-planejamento-estrategico": "tsx scripts/consultoria_gerar_planejamento_estrategico.ts",
    "consultoria:gerar-resumo-executivo": "tsx scripts/consultoria_gerar_resumo_executivo.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@sentry/react": "^10.53.1",
    "@sentry/vite-plugin": "^5.3.0",
    "@supabase/supabase-js": "^2.102.1",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.99.0",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.0.0",
    "lucide-react": "^0.575.0",
    "motion": "^12.23.24",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^18.3.1",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "web-vitals": "^4.2.4",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@happy-dom/global-registrator": "^20.7.0",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/html2pdf.js": "^0.10.0",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "bun-types": "^1.3.10",
    "dotenv": "^17.4.1",
    "eslint": "^10.4.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "exceljs": "^4.4.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.8.9",
    "node-cron": "^4.2.1",
    "playwright": "^1.59.1",
    "resend": "^6.10.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.59.4",
    "vercel": "^50.40.0",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  }
}
