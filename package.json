{
  "name": "mx-performance",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit && node scripts/lint-tokens.js",
    "lint:tokens": "node scripts/lint-tokens.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/lib src/benchmarks src/hooks src/components src/test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "sync:ide": "node .aiox-core/infrastructure/scripts/ide-sync/index.js sync",
    "sync:ide:check": "node .aiox-core/infrastructure/scripts/ide-sync/index.js validate",
    "sync:skills:codex": "node .aiox-core/infrastructure/scripts/codex-skills-sync/index.js",
    "sync:skills:codex:global": "node .aiox-core/infrastructure/scripts/codex-skills-sync/index.js --global",
    "validate:structure": "node .aiox-core/infrastructure/scripts/validate-paths.js",
    "validate:agents": "node .aiox-core/infrastructure/scripts/validate-agents.js",
    "deploy": "vercel --prod",
    "fix:admin-access": "tsx scripts/fix_admin_access.ts",
    "seed:sandbox:live": "tsx scripts/seed_live_sandbox.ts",
    "validate:e2e:live": "tsx scripts/validate_live_end_to_end.ts",
    "consulting:seed-parameters": "tsx scripts/consulting_seed_parameters.ts",
    "consulting:import-monthly-close": "tsx scripts/consulting_import_monthly_close.ts",
    "consulting:generate-strategic-plan": "tsx scripts/consulting_generate_strategic_plan.ts",
    "consulting:generate-executive-summary": "tsx scripts/consulting_generate_executive_summary.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.575.0",
    "motion": "^12.23.24",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.7.0",
    "@playwright/test": "^1.58.2",
    "@supabase/supabase-js": "^2.102.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "bun-types": "^1.3.10",
    "dotenv": "^17.4.1",
    "exceljs": "^4.4.0",
    "happy-dom": "^20.8.9",
    "node-cron": "^4.2.1",
    "playwright": "^1.59.1",
    "resend": "^6.10.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vercel": "^50.40.0",
    "vite": "^6.2.0"
  }
}
