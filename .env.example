# MX PERFORMANCE - variáveis de ambiente
# Copie para `.env` e preencha com valores reais.
# Nunca commite `.env` com credenciais.

# Aplicação Vite / Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase server-side / scripts operacionais
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Serviço auxiliar WhatsApp
VITE_WHATSAPP_API_URL=http://localhost:3001
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000

# Deploy / automação
VERCEL_TOKEN=
GITHUB_TOKEN=

# Ambiente
NODE_ENV=development
