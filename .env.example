# ============================================
# Synkra AIOX Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real credentials
# ============================================

# --------------------------------------------
# LLM Providers
# --------------------------------------------

# DeepSeek API (for claude-free command)
# Get your key at: https://platform.deepseek.com/api_keys
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=

# OpenRouter API (server-side AI summaries and multi-model routing)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_PRIMARY_MODEL=openrouter/free
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-v4-flash:free
# OpenRouter free tier without credits is 50 requests/day and 20 RPM.
# Keep a safety buffer; if the account has at least US$10 credits, this can be raised.
OPENROUTER_PRIMARY_DAILY_LIMIT=40
OPENROUTER_FALLBACK_DAILY_LIMIT=5
OPENROUTER_SITE_URL=https://mxperformance.vercel.app
OPENROUTER_APP_NAME=MX Performance

# Anthropic API (direct, if not using Claude Max subscription)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --------------------------------------------
# Search & Research Tools
# --------------------------------------------

# Exa Search API (web search for agents)
# Get your key at: https://exa.ai/
EXA_API_KEY=

# Context7 (library documentation lookup)
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=

# --------------------------------------------
# Database & Backend
# --------------------------------------------

# Supabase (database, auth, storage)
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Playwright E2E authenticated smoke tests.
# E2E_AUTH_EMAIL defaults to the MX admin master account used in local QA.
# Keep real passwords only in local .env, never in git.
E2E_AUTH_EMAIL=synvollt@gmail.com
E2E_AUTH_PASSWORD=
E2E_ROLE_PASSWORD=

# Google OAuth / Workspace integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_TOKEN_ENCRYPTION_SECRET=
GOOGLE_CENTRAL_CALENDAR_EMAIL=gestao@mxconsultoria.com.br
GOOGLE_CENTRAL_CALENDAR_ID=primary
GOOGLE_CENTRAL_DRIVE_ROOT_FOLDER_ID=
GOOGLE_CENTRAL_DRIVE_ROOT_FOLDER_NAME=MX Performance - Clientes

# --------------------------------------------
# Version Control & CI/CD
# --------------------------------------------

# GitHub Token (for GitHub CLI and API access)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=

# --------------------------------------------
# Project Management
# --------------------------------------------

# ClickUp API (if using ClickUp integration)
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=

# --------------------------------------------
# Automation & Workflows
# --------------------------------------------

# N8N (workflow automation)
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=

# --------------------------------------------
# Monitoring & Analytics
# --------------------------------------------

# Sentry (error tracking + observability) — Story 0.3 / SYS-017 / X-8
# FE (Vite-prefixed, expostos no bundle)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_RELEASE=
# Build-time (Vite plugin upload de source maps; NUNCA expor no client)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Edge Functions (Supabase Dashboard → Functions → Secrets)
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=

# --------------------------------------------
# Cloud Providers
# --------------------------------------------

# Railway (deployment)
RAILWAY_TOKEN=

# Vercel (deployment)
VERCEL_TOKEN=

# --------------------------------------------
# AIOX Core Configuration
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=2.2.0

# --------------------------------------------
# Custom Configuration
# --------------------------------------------
# Add your custom API keys below

# === AIOX Variables (added 2026-05-07) ===

# AIOX_NOTE: The following variables already exist with different values:
# AIOX_SUGGESTED: AIOX_VERSION=5.1.15
